{
  "name": "taskflow",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@taskflow/web",
    "dev:desktop": "npm run dev --workspace=@taskflow/desktop",
    "build": "turbo run build",
    "build:web": "npm run build --workspace=@taskflow/web",
    "typecheck": "turbo run typecheck",
    "dev:mobile": "npm run start --workspace=@taskflow/mobile",
    "test": "turbo run test"
  },
  "packageManager": "npm@11.9.0",
  "devDependencies": {
    "turbo": "^2.4.0",
    "vitest": "^4.0.18"
  }
}
